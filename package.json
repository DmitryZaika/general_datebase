{
  "name": "my-remix-app",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "react-router typegen && tsc && react-router build && npm run build:sw && npm run build:sw-inject && npm run copy-sw",
    "build:sw": "vite build --config vite.sw.config.ts",
    "build:sw-inject": "node scripts/build-sw.js",
    "copy-sw": "node scripts/copy-sw-to-public.js",
    "dev": "react-router dev",
    "start": "react-router-serve build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "migrate": "tsx scripts/migrate.ts",
    "hash-password": "node scripts/hash-password.js",
    "prod-deploy": "bun run build && export $(grep -v '^#' .env | xargs -0) && nohup react-router-serve ./build/server/index.js > build.log 2>&1 &",
    "prod-kill": "kill -9 $(lsof -t -i:3000)",
    "prod-restart": "bun run prod-kill && npm run prod-deploy",
    "load-data": "node scripts/load-stones-csv.js",
    "test": "vitest",
    "shrink-images": "tsx scripts/images.ts",
    "send-email": "tsx scripts/send-email.ts"
  },
