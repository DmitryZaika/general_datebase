{
  "name": "my-remix-app",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "tsc -b && react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "migrate": "tsx scripts/migrate.ts",
    "hash-password": "node scripts/hash-password.js",
    "prod-deploy": "react-router build && export $(grep -v '^#' .env | xargs -0) && nohup react-router-serve ./build/server/index.js > build.log 2>&1 &",
    "prod-kill": "kill -9 $(lsof -t -i:3000)",
    "prod-restart": "npm run prod-kill && npm run prod-deploy",
    "load-data": "node scripts/load-stones-csv.js",
    "test": "vitest",
    "shrink-images": "tsx scripts/images.ts",
    "send-email": "tsx scripts/send-email.ts"
  },
